#!/bin/zsh
# Find the project directory (wherever this .app is)
APP_DIR="$(cd "$(dirname "$0")/../.." && pwd -P)"
PROJ_DIR="$(dirname "$APP_DIR")"

# If the .app is inside the project, use parent; else use ~/NeuraDictate-project
if [ -f "$PROJ_DIR/start.py" ]; then
    cd "$PROJ_DIR"
elif [ -f "$HOME/NeuraDictate/start.py" ]; then
    cd "$HOME/NeuraDictate"
elif [ -f "/Applications/NeuraDictate/start.py" ]; then
    cd "/Applications/NeuraDictate"
else
    # Fall back: project alongside the .app
    cd "$PROJ_DIR"
fi

# Launch headless
export NEURADICTATE_HEADLESS=1
exec /usr/bin/env python3 start.py
